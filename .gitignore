# Python bytecode caches
**/__pycache__/
*.py[cod]

# Editable install metadata
*.egg-info/

# Local FFmpeg binaries for offline tests
ffmpeg-bin/

# Local corpora for tests (JSUT, LibriSpeech, etc.)
tests/assets/source/
tests/assets/audio/*.flac

# Generated benchmark data
tests/assets/prepared/

# Benchmark output
benchmark_results/

# Local-only speaker benchmark data: source audio is git-unshareable (stream
# clips), but the label template (transcripts only, no audio) may be committed.
benchmarks/speaker/data/*
!benchmarks/speaker/data/labels_template.csv
